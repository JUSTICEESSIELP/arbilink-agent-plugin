{
  "name": "arbilink",
  "version": "1.1.0",
  "description": "OpenClaw plugin enabling AI agents to interact with Arbitrum — read balances, check gas, query tokens, read smart contracts, verify agent identity, and perform cross-chain transactions via ChainRails.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "arbitrum",
    "openclaw",
    "plugin",
    "ai-agent",
    "web3",
    "defi",
    "wallet",
    "cross-chain",
    "chainrails",
    "bridge"
  ],
  "license": "MIT",
  "dependencies": {
    "@chainrails/sdk": "^0.3.8",
    "@sinclair/typebox": "0.34.48",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": "2026.4"
    },
    "build": {
      "openclawVersion": "2026.4.1"
    }
  }
}
